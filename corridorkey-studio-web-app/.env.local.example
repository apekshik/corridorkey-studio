# ---------------------------------------------------------------------------
# WorkOS AuthKit
# ---------------------------------------------------------------------------
# Get these from https://dashboard.workos.com/ (create an AuthKit app)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# 32-byte base64 string — generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# e.g. http://localhost:3000/callback (dev) / https://yourdomain.com/callback (prod)
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# AuthKit issuer domain — visible on the WorkOS dashboard, e.g.
# https://brave-grass-42-staging.authkit.app
WORKOS_ISSUER=

# ---------------------------------------------------------------------------
# Convex
# ---------------------------------------------------------------------------
# Set by `npx convex dev` / `npx convex deploy`. Both are public.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# ---------------------------------------------------------------------------
# fal.ai (used from Convex actions, never exposed to the browser)
# ---------------------------------------------------------------------------
# Set this in the Convex dashboard via `npx convex env set FAL_KEY ...`
# Listed here for local reference only.
# FAL_KEY=
